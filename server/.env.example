# ── Server ─────────────────────────────────────────────
NODE_ENV=development
PORT=5000
# Comma-separate multiple allowed origins (local dev, Vercel prod, Vercel previews)
CLIENT_ORIGIN=http://localhost:5173

# ── Database ───────────────────────────────────────────
MONGO_URI=mongodb://127.0.0.1:27017/nexus

# ── JWT ────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace-with-a-long-random-string
JWT_REFRESH_SECRET=replace-with-a-different-long-random-string
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=7d

# ── Cookies (refresh token) ────────────────────────────
# In production (cross-site Vercel+Render): COOKIE_SECURE=true, COOKIE_SAMESITE=none
COOKIE_SECURE=false
COOKIE_SAMESITE=lax

# ── Email (dev: leave SMTP_* blank to auto-create an Ethereal test inbox) ──
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=Nexus <no-reply@nexus.local>
CLIENT_RESET_URL=http://localhost:5173/reset-password

# ── File storage (local | cloudinary) ─────────────────
STORAGE_DRIVER=local
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Stripe (test mode — Phase 3) ───────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
